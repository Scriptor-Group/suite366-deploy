# =============================================================================
# Suite 366 — configuration
# Copy this file to ".env" and fill in the values. The installer (curl | sh)
# does this for you and pre-generates the secrets marked "auto-generated".
# =============================================================================

# ---- Public URLs ------------------------------------------------------------
# The address users reach the app at. Behind a domain + reverse proxy, set both
# to your HTTPS URL, e.g. https://suite366.example.com
APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
APP_PORT=3000

# ---- Authentication (Auth.js) ----------------------------------------------
# auto-generated — a random 32-byte base64 secret. openssl rand -base64 32
AUTH_SECRET=

# ---- Database (PostgreSQL + pgvector) --------------------------------------
POSTGRES_DB=suite366
POSTGRES_USER=suite366
# auto-generated — MUST match the password inside DATABASE_URL below.
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://suite366:CHANGE_ME@postgres:5432/suite366?schema=public

# ---- Cache / queues (Redis) -------------------------------------------------
REDIS_HOST=redis

# ---- Object storage (MinIO / S3-compatible) --------------------------------
MINIO_ENDPOINT=http://minio:9000
# auto-generated
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=suite-366
MINIO_CONSOLE_PORT=9001

# ---- Server Actions encryption ---------------------------------------------
# Leave EMPTY for a single-instance deployment: the container mints an
# ephemeral key at startup. For multi-replica/HA, set the SAME base64 value
# (openssl rand -base64 32) on every replica. See docs/configuration.md.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ---- Licensing (required) ---------------------------------------------------
# Public verification key provided by Devana. Required to run in production;
# then activate your subscription with a license key inside the app.
LICENSE_PUBLIC_KEY=

# ---- AI features (optional, recommended) -----------------------------------
# Powers embeddings, semantic search (RAG) and chat. Leave empty to disable.
OPENAI_API_KEY=

# ---- Collaborative editing (optional) --------------------------------------
# Required only if you enable the onlyoffice service in docker-compose.yml.
# ONLYOFFICE_URL=http://localhost:8080
# ONLYOFFICE_JWT_SECRET=
# ONLYOFFICE_PORT=8080

# ---- On-host GPU inference (docker-compose.gpu.yml) -------------------------
# Only needed when running the vLLM overlay on an NVIDIA GPU appliance
# (DGX Spark / GB10). See docs/gpu-inference.md.
#
# Hugging Face token to download the models on first boot (then cached).
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# API key the app sends to the local vLLM endpoint (vLLM ignores it unless you
# configure --api-key on the server; any non-empty value works).
# LLM_API_KEY=local-vllm
#
# Set both to 1 only AFTER the models are cached, to boot fully offline.
# HF_HUB_OFFLINE=0
# TRANSFORMERS_OFFLINE=0
